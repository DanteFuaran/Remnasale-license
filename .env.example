# Токен Telegram бота (получить у @BotFather)
BOT_TOKEN=

# Telegram ID администратора
BOT_ADMIN_ID=

# Настройки API сервера
API_HOST=0.0.0.0
API_PORT=8080

# Путь к базе данных
DATABASE_PATH=/data/license.db

# URL сайта DFC (если был указан домен при установке)
SITE_URL=

# URL лицензионного сервера
LICENSE_SERVER_URL=

# GitHub PAT для скачивания скрипта установки из приватного репозитория
GITHUB_PAT=

# Прокси для подключения к Telegram API (если сервер в заблокированной стране)
# Формат: socks5://user:pass@host:port  или  http://user:pass@host:port
TELEGRAM_PROXY=
